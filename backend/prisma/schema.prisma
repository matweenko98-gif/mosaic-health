generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  passwordHash         String
  role                 Role              @default(PATIENT)
  name                 String            @default("")
  phone                String            @default("")
  age                  String            @default("")
  country              String            @default("")
  hasRehabilitation    Boolean           @default(false)
  avatarKey            String?
  emailVerifiedAt      DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  codesActivated       AccessCode[]      @relation("ActivatedCodes")
  codesCreated         AccessCode[]      @relation("SpecialistCodes")
  authoredArticles     Article[]
  emailTokens          EmailToken[]
  orders               Order[]
  programsAsPatient    Program[]         @relation("PatientPrograms")
  programsAsSpecialist Program[]         @relation("SpecialistPrograms")
  programProgress      ProgramProgress[]
  settings             UserSettings?
  workoutLogs          WorkoutLog[]
}

model AccessCode {
  id            String    @id @default(cuid())
  code          String    @unique
  label         String    @default("")
  specialistId  String
  activatedById String?
  activatedAt   DateTime?
  createdAt     DateTime  @default(now())
  activatedBy   User?     @relation("ActivatedCodes", fields: [activatedById], references: [id])
  specialist    User      @relation("SpecialistCodes", fields: [specialistId], references: [id])
}

model UserSettings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  workoutReminders     Boolean @default(true)
  articleNotifications Boolean @default(false)
  language             String  @default("RU")
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailToken {
  id        String         @id @default(cuid())
  userId    String
  type      EmailTokenType
  token     String         @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           Int           @id @default(autoincrement())
  title        String
  description  String        @default("")
  durationMin  Int           @default(0)
  category     String        @default("Общее")
  videoKey     String?
  isIndividual Boolean       @default(false)
  createdAt    DateTime      @default(now())
  programItems ProgramItem[]
}

model Program {
  id           String           @id @default(cuid())
  title        String           @default("Индивидуальная программа")
  patientId    String
  specialistId String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  patient      User             @relation("PatientPrograms", fields: [patientId], references: [id], onDelete: Cascade)
  specialist   User             @relation("SpecialistPrograms", fields: [specialistId], references: [id])
  items        ProgramItem[]
  progress     ProgramProgress?
}

model ProgramItem {
  id         String   @id @default(cuid())
  programId  String
  exerciseId Int
  order      Int      @default(0)
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, exerciseId])
}

model ProgramProgress {
  id           String   @id @default(cuid())
  userId       String
  programId    String   @unique
  currentIndex Int      @default(-1)
  queue        Json     @default("[]")
  updatedAt    DateTime @updatedAt
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutLog {
  id             String   @id @default(cuid())
  userId         String
  exerciseId     Int?
  programId      String?
  name           String
  status         String   @default("Выполнено")
  isIndividual   Boolean  @default(false)
  completedCount Int      @default(0)
  totalCount     Int      @default(0)
  exercises      Json     @default("[]")
  completedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  body        String   @default("")
  readTime    String   @default("")
  authorId    String?
  publishedAt DateTime @default(now())
  author      User?    @relation(fields: [authorId], references: [id])
}

model Podcast {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  durationMin Int      @default(0)
  audioKey    String?
  publishedAt DateTime @default(now())
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Int
  description String      @default("")
  category    String      @default("Общее")
  imageKey    String?
  inStock     Boolean     @default(true)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  recipientName String
  phone         String
  address       String
  total         Int
  status        OrderStatus @default(NEW)
  createdAt     DateTime    @default(now())
  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId Int?
  name      String
  price     Int
  quantity  Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
}

enum Role {
  PATIENT
  SPECIALIST
  ADMIN
}

enum EmailTokenType {
  VERIFY
  RESET
}

enum OrderStatus {
  NEW
  CONFIRMED
  SHIPPED
  CANCELLED
}
